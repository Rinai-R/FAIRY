{
  "version": "0.1.0",
  "providers": [
    {
      "domain": "voice",
      "id": "style-bert-vits2",
      "display_name": "Style-Bert-VITS2",
      "description": "示例外部语音 provider manifest，后续可映射到 HTTP TTS adapter。",
      "default_endpoint": "http://127.0.0.1:5000",
      "adapter": "http_voice",
      "http_voice": {
        "endpoint": "http://127.0.0.1:5000",
        "method": "POST",
        "path": "/voice",
        "content_type": "application/json",
        "body_template": "{\"text\":\"{{text}}\",\"model_id\":\"{{voice_id}}\",\"style\":\"{{style}}\",\"length\":{{speed}}}",
        "output_format": "wav",
        "health_path": "/docs"
      }
    }
  ]
}
