{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FAIRY",
  "version": "0.1.0",
  "identifier": "dev.rinai.fairy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "companion",
        "title": "FAIRY",
        "width": 260,
        "height": 380,
        "minWidth": 260,
        "minHeight": 380,
        "maxWidth": 600,
        "maxHeight": 420,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "control-panel",
        "title": "FAIRY 控制面板",
        "width": 560,
        "height": 620,
        "minWidth": 560,
        "minHeight": 620,
        "maxWidth": 560,
        "maxHeight": 620,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
